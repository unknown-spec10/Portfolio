rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Safety net
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isValidId(id) { return id is string && id.size() <= 128; }
    
    // User Profile Rules
    match /users/{userId} {
      function isValidProfile(data) {
        return data.keys().hasAll(['uid', 'username', 'displayName']) &&
               data.uid == request.auth.uid &&
               data.username is string && data.username.size() >= 3 &&
               data.displayName is string && data.displayName.size() <= 100;
      }

      allow read: if true;
      allow create: if isOwner(userId) && isValidProfile(request.resource.data);
      allow update: if isOwner(userId) && isValidProfile(request.resource.data) &&
                      request.resource.data.uid == resource.data.uid &&
                      request.resource.data.username == resource.data.username;
    }

    // Project Rules
    match /projects/{projectId} {
      function isValidProject(data) {
        return data.keys().hasAll(['id', 'userId', 'name', 'status']) &&
               data.userId == request.auth.uid &&
               data.name is string && data.name.size() <= 120 &&
               data.status in ['draft', 'public'];
      }

      allow read: if true; // Public projects and drafts for owners (handled by query filtering best practice, but rules must allow)
      // Actually, better to restrict draft reading:
      allow list: if resource.data.status == 'public' || isOwner(resource.data.userId);
      allow get: if resource.data.status == 'public' || isOwner(resource.data.userId);
      
      allow create: if isSignedIn() && isValidProject(request.resource.data) && isValidId(projectId);
      allow update: if isOwner(resource.data.userId) && isValidProject(request.resource.data) &&
                      request.resource.data.userId == resource.data.userId;
      allow delete: if isOwner(resource.data.userId);
    }
  }
}
